{
  "mode": "interactive",
  "granularity": "standard",
  "workflow": {
    "research": false,
    "plan_check": true,
    "verifier": true,
    "auto_advance": false,
    "nyquist_validation": true,
    "security_enforcement": true,
    "security_asvs_level": 1,
    "security_block_on": "high",
    "discuss_mode": "discuss",
    "research_before_questions": false,
    "code_review": true,
    "code_review_command": null,
    "code_review_depth": "standard",
    "plan_bounce": false,
    "plan_bounce_script": null,
    "plan_bounce_passes": 2,
    "cross_ai_execution": false,
    "cross_ai_command": "",
    "cross_ai_timeout": 300
  },
  "ship": {
    "pr_body_sections": [
      {
        "heading": "User Stories & Acceptance Criteria",
        "enabled": true,
        "source": "REQUIREMENTS.md ## v1 Requirements",
        "fallback": "- Acceptance criteria are covered by requirements and verification evidence."
      },
      {
        "heading": "Risks & Dependencies",
        "enabled": true,
        "source": "STATE.md ## Blockers/Concerns",
        "fallback": "- No known high-risk rollout dependencies."
      }
    ]
  },
  "planning": {
    "commit_docs": true,
    "search_gitignored": false,
    "sub_repos": []
  },
  "git": {
    "create_tag": true
  },
  "parallelization": {
    "enabled": true,
    "plan_level": true,
    "task_level": false,
    "skip_checkpoints": true,
    "max_concurrent_agents": 3,
    "min_plans_for_parallel": 2
  },
  "hooks": {
    "context_warnings": true
  },
  "project_code": "quota-radar",
  "agent_skills": {},
  "claude_md_path": "./AGENTS.md"
}
